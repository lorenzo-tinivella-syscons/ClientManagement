                            expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns1=&quot;http://www.example.org/Client&quot; version=&quot;2.0&quot;>&lt;xsl:param name=&quot;JDBCQuery&quot;/>&lt;xsl:template name=&quot;End-input&quot; match=&quot;/&quot;>&lt;tns1:GetClientDetailsResponse>&lt;tns1:Name>&lt;xsl:value-of select=&quot;$JDBCQuery/Record[1]/name&quot;/>&lt;/tns1:Name>&lt;tns1:Email>&lt;xsl:value-of select=&quot;$JDBCQuery/Record[1]/email&quot;/>&lt;/tns1:Email>&lt;tns1:PhoneNumber>&lt;xsl:value-of select=&quot;$JDBCQuery/Record[1]/phone_number&quot;/>&lt;/tns1:PhoneNumber>&lt;/tns1:GetClientDetailsResponse>&lt;/xsl:template>&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
