                                    sharedResourceProperty="jdbcProperty"
                                    sqlStatement="SELECT name, email, phone_number FROM clients WHERE id = ?&#xa;"
                                    timeout="10" xsi:type="jdbcPalette:JDBCQueryActivity">
                                    <PreparedParameters DataType="4"
