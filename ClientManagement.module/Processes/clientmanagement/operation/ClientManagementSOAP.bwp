            <plnk:partnerLinkType name="partnerLinkType">
                <plnk:role name="use" portType="ptyp:ClientManagementPortType"/>
            </plnk:partnerLinkType>
            <wsdl:import namespace="http://www.tibco.com/ClientManagementDescriptor/"/>
        </wsdl:definitions>
