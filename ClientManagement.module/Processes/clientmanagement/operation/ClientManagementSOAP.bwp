&lt;xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:tns1="http://www.tibco.com/ClientManagementDescriptor/" xmlns:tns="http://www.example.org/Client" version="2.0"&gt;&lt;xsl:param name="FaultDetails"/&gt;&lt;xsl:template name="Reply_registerClientError-input" match="/"&gt;&lt;tns1:ClientFault&gt;&lt;fault&gt;&lt;tns:ClientFault&gt;&lt;tns:Code&gt;&lt;xsl:value-of select="$FaultDetails/MsgCode"/&gt;&lt;/tns:Code&gt;&lt;tns:Description&gt;&lt;xsl:value-of select="$FaultDetails/Msg"/&gt;&lt;/tns:Description&gt;&lt;/tns:ClientFault&gt;&lt;/fault&gt;&lt;/tns1:ClientFault&gt;&lt;/xsl:template&gt;&lt;/xsl:stylesheet&gt;</tibex:inputBinding>
